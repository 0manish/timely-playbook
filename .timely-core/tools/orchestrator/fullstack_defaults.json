{
  "schema_version": 1,
  "paper": {
    "arxiv_id": "2602.03798",
    "title": "FullStack-Agent: Enhancing Agentic Full-Stack Web Coding via Development-Oriented Testing and Repository Back-Translation",
    "url": "https://arxiv.org/abs/2602.03798"
  },
  "default_stack": "codex_symphony",
  "default_provider": "codex",
  "default_adapter": "symphony",
  "default_orchestration_mode": "symphony",
  "default_model": "gpt-5-codex",
  "adapters": {
    "direct_cli": {
      "label": "Direct CLI execution",
      "submit_command": [],
      "stdin_payload": "none",
      "completion_mode": "sync_exec",
      "fallback_to_provider": true
    },
    "symphony": {
      "label": "Symphony handoff",
      "submit_command": [],
      "sample_submit_command": [
        "bash",
        ".timely-playbook/bin/symphony-submit.sh",
        "--payload",
        "{payload_file}",
        "--prompt",
        "{prompt_file}",
        "--run-dir",
        "{run_dir}"
      ],
      "stdin_payload": "json",
      "completion_mode": "async_handoff",
      "fallback_to_provider": true,
      "notes": [
        "Set adapters.symphony.submit_command in .timely-playbook/local/.orchestrator/fullstack-agent.json to hand work to an external Symphony service.",
        "The template ships a starter wrapper at .timely-playbook/bin/symphony-submit.sh; copy sample_submit_command into submit_command to use it.",
        "The submit command receives a payload file path via {payload_file} and a rendered prompt via {prompt_file}.",
        "When submit_command is empty, Timely falls back to local provider execution so seeded repos remain runnable."
      ]
    }
  },
  "stacks": {
    "codex_symphony": {
      "label": "Codex + Symphony",
      "provider": "codex",
      "adapter": "symphony",
      "orchestration_mode": "symphony",
      "description": "Default Timely stack: Symphony-style ticket orchestration with Codex execution."
    },
    "codex_cli": {
      "label": "Codex CLI",
      "provider": "codex",
      "adapter": "direct_cli",
      "orchestration_mode": "direct_cli",
      "description": "Direct CLI execution without a Symphony control plane."
    },
    "claude_symphony_example": {
      "label": "Claude + Symphony example",
      "provider": "claude_code_example",
      "adapter": "symphony",
      "orchestration_mode": "symphony",
      "description": "Example stack showing how a project could keep Symphony orchestration while swapping execution to Claude Code."
    },
    "open_source_symphony_example": {
      "label": "Open-source + Symphony example",
      "provider": "open_source_agent_example",
      "adapter": "symphony",
      "orchestration_mode": "symphony",
      "description": "Example stack showing how a project could keep Symphony orchestration while swapping execution to an open-source agent."
    }
  },
  "providers": {
    "codex": {
      "label": "Codex CLI",
      "stdin_prompt": true,
      "exec_command": [
        "codex",
        "exec",
        "--skip-git-repo-check",
        "--cd",
        "{workdir}",
        "--output-last-message",
        "{run_dir}/agent-last-message.txt",
        "{model_args}",
        "-"
      ],
      "model_arg": [
        "--model",
        "{model}"
      ]
    },
    "claude_code_example": {
      "label": "Claude Code example",
      "stdin_prompt": true,
      "exec_command": [],
      "sample_exec_command": [
        "bash",
        ".timely-playbook/bin/claude-code-example.sh",
        "--workdir",
        "{workdir}",
        "{model_args}"
      ],
      "model_arg": [
        "--model",
        "{model}"
      ],
      "notes": [
        "Example only: copy sample_exec_command into exec_command, then set TIMELY_CLAUDE_CODE_COMMAND in your environment or CI.",
        "The template ships a starter wrapper at .timely-playbook/bin/claude-code-example.sh.",
        "Keep stdin_prompt=true if your Claude wrapper reads the rendered prompt from stdin."
      ]
    },
    "open_source_agent_example": {
      "label": "Open-source agent example",
      "stdin_prompt": true,
      "exec_command": [],
      "sample_exec_command": [
        "bash",
        ".timely-playbook/bin/open-source-agent-example.sh",
        "--workdir",
        "{workdir}",
        "{model_args}"
      ],
      "model_arg": [
        "--model",
        "{model}"
      ],
      "notes": [
        "Example only: copy sample_exec_command into exec_command, then set TIMELY_OPEN_SOURCE_AGENT_COMMAND in your environment or CI.",
        "The template ships a starter wrapper at .timely-playbook/bin/open-source-agent-example.sh.",
        "Use the same stack and adapter surfaces if you later switch between local direct CLI and external Symphony handoff."
      ]
    }
  },
  "projects_dir": "fullstack-projects",
  "upstreams": [
    {
      "id": "fullstack-agent",
      "url": "https://github.com/mnluzimu/FullStack-Agent.git",
      "ref": "f0d29a36e2ba34d559fd5d6fcf2268802ccc7a3b",
      "local_path": ".timely-playbook/local/.orchestrator/upstream/fullstack-agent"
    },
    {
      "id": "fullstack-dev",
      "url": "https://github.com/mnluzimu/FullStack-Dev.git",
      "ref": "3aa1378ebed0c0e3cfeabb3a2b941396cc480451",
      "local_path": ".timely-playbook/local/.orchestrator/upstream/fullstack-dev"
    },
    {
      "id": "fullstack-bench",
      "url": "https://github.com/mnluzimu/FullStack-Bench.git",
      "ref": "9e4cbb593e803309275cc642c5530f2092d7832b",
      "local_path": ".timely-playbook/local/.orchestrator/upstream/fullstack-bench"
    },
    {
      "id": "fullstack-learn",
      "url": "https://github.com/mnluzimu/FullStack-Learn.git",
      "ref": "3667b79f0ec282a985c5f8da719f8ebe3ec0adfe",
      "local_path": ".timely-playbook/local/.orchestrator/upstream/fullstack-learn"
    }
  ],
  "templates": {
    "nextjs-nestjs-postresql": {
      "mode": "coupled",
      "repo": "fullstack-dev",
      "path": "templates/nextjs-nestjs-postresql"
    },
    "nextjs__nestjs": {
      "mode": "decoupled",
      "repo": "fullstack-dev",
      "common_path": "templates_decoupled/common_files",
      "frontend_path": "templates_decoupled/nextjs",
      "backend_path": "templates_decoupled/nestjs"
    },
    "nextjs__django": {
      "mode": "decoupled",
      "repo": "fullstack-dev",
      "common_path": "templates_decoupled/common_files",
      "frontend_path": "templates_decoupled/nextjs",
      "backend_path": "templates_decoupled/django"
    },
    "vue__nestjs": {
      "mode": "decoupled",
      "repo": "fullstack-dev",
      "common_path": "templates_decoupled/common_files",
      "frontend_path": "templates_decoupled/vue",
      "backend_path": "templates_decoupled/nestjs"
    },
    "vue__django": {
      "mode": "decoupled",
      "repo": "fullstack-dev",
      "common_path": "templates_decoupled/common_files",
      "frontend_path": "templates_decoupled/vue",
      "backend_path": "templates_decoupled/django"
    }
  },
  "phases": [
    {
      "id": "architecture",
      "title": "Plan architecture and acceptance criteria",
      "prompt_template": ".timely-core/tools/orchestrator/fullstack_prompts/01_architecture.md",
      "validation_commands": [
        "test -f docs/fullstack-agent/architecture.md"
      ]
    },
    {
      "id": "backend",
      "title": "Implement backend with development-oriented API testing",
      "prompt_template": ".timely-core/tools/orchestrator/fullstack_prompts/02_backend.md",
      "validation_commands": [
        "test -f docs/fullstack-agent/backend-testing.md"
      ]
    },
    {
      "id": "frontend",
      "title": "Implement frontend with development-oriented UI testing",
      "prompt_template": ".timely-core/tools/orchestrator/fullstack_prompts/03_frontend.md",
      "validation_commands": [
        "test -f docs/fullstack-agent/frontend-testing.md"
      ]
    },
    {
      "id": "integration",
      "title": "Complete integration across API, UI, and data model",
      "prompt_template": ".timely-core/tools/orchestrator/fullstack_prompts/04_integration.md",
      "validation_commands": [
        "test -f docs/fullstack-agent/integration-report.md"
      ]
    },
    {
      "id": "backtranslation",
      "title": "Capture back-translation artifacts and release checklist",
      "prompt_template": ".timely-core/tools/orchestrator/fullstack_prompts/05_backtranslation.md",
      "validation_commands": [
        "test -f docs/fullstack-agent/release-readiness.md"
      ]
    }
  ]
}
